{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://osint-core.corbello.io/schemas/plan-v1.schema.json",
  "title": "OSINT Collection Plan v1",
  "description": "Schema for OSINT collection plan YAML files — defines sources, scoring rules, and notification routing.",
  "type": "object",
  "required": ["version", "plan_id", "sources", "scoring", "notifications"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version, must be 1."
    },
    "plan_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$",
      "description": "Unique lowercase-hyphenated identifier for the plan."
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Human-readable description of the plan."
    },
    "retention_class": {
      "type": "string",
      "enum": ["ephemeral", "standard", "evidentiary"],
      "default": "standard",
      "description": "Data retention class governing how long collected items are stored."
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "description": "List of OSINT sources to collect from.",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "Unique identifier for this source within the plan."
          },
          "type": {
            "type": "string",
            "enum": [
              "rss",
              "sitemap",
              "http_html",
              "http_pdf",
              "http_json",
              "nvd_json_feed",
              "osv_api",
              "cisa_kev",
              "urlhaus_api",
              "threatfox_api",
              "github_releases"
            ],
            "description": "Source collector type."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL endpoint for the source."
          },
          "weight": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 10.0,
            "default": 1.0,
            "description": "Scoring weight multiplier for items from this source."
          },
          "schedule_cron": {
            "type": "string",
            "description": "Cron expression for collection schedule."
          },
          "params": {
            "type": "object",
            "description": "Arbitrary source-specific parameters.",
            "additionalProperties": true
          }
        }
      }
    },
    "scoring": {
      "type": "object",
      "required": ["recency_half_life_hours", "source_reputation", "ioc_match_boost"],
      "additionalProperties": false,
      "description": "Scoring configuration for collected items.",
      "properties": {
        "recency_half_life_hours": {
          "type": "number",
          "minimum": 1,
          "maximum": 8760,
          "description": "Half-life in hours for the recency decay function."
        },
        "source_reputation": {
          "type": "object",
          "description": "Map of source id to reputation multiplier.",
          "additionalProperties": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 10.0
          }
        },
        "ioc_match_boost": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 100.0,
          "description": "Score multiplier when an IOC match is found."
        },
        "force_alert": {
          "type": "object",
          "description": "Conditions that force an immediate alert regardless of score.",
          "additionalProperties": false,
          "properties": {
            "min_severity": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"],
              "description": "Minimum severity level to trigger a forced alert."
            },
            "tags_any": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "If any of these tags are present, force an alert."
            }
          }
        }
      }
    },
    "notifications": {
      "type": "object",
      "required": ["routes"],
      "additionalProperties": false,
      "description": "Notification routing and deduplication settings.",
      "properties": {
        "default_dedupe_window_minutes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10080,
          "default": 60,
          "description": "Default deduplication window in minutes."
        },
        "quiet_hours": {
          "type": "object",
          "description": "Suppress non-critical notifications during these hours.",
          "additionalProperties": false,
          "properties": {
            "timezone": {
              "type": "string",
              "description": "IANA timezone identifier."
            },
            "start": {
              "type": "string",
              "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
              "description": "Start time in HH:MM format."
            },
            "end": {
              "type": "string",
              "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
              "description": "End time in HH:MM format."
            }
          }
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "description": "Notification routing rules evaluated in order.",
          "items": {
            "type": "object",
            "required": ["name", "channels"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Human-readable name for this route."
              },
              "when": {
                "type": "object",
                "description": "Conditions that must be met to trigger this route.",
                "additionalProperties": false,
                "properties": {
                  "severity_gte": {
                    "type": "string",
                    "enum": ["low", "medium", "high", "critical"],
                    "description": "Minimum severity level."
                  },
                  "tags_any": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Match if any of these tags are present."
                  },
                  "source_ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Match only items from these source ids."
                  }
                }
              },
              "channels": {
                "type": "array",
                "minItems": 1,
                "description": "Notification channels to dispatch to.",
                "items": {
                  "type": "object",
                  "required": ["type"],
                  "additionalProperties": false,
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["gotify", "slack", "email", "webhook"],
                      "description": "Channel type."
                    },
                    "application": {
                      "type": "string",
                      "description": "Application name (gotify)."
                    },
                    "priority": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 10,
                      "description": "Notification priority (gotify)."
                    },
                    "url": {
                      "type": "string",
                      "format": "uri",
                      "description": "Webhook URL or endpoint."
                    },
                    "to": {
                      "type": "string",
                      "description": "Email recipient address."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
