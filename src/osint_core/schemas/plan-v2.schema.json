{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://osint-core.corbello.io/schemas/plan-v2.schema.json",
  "title": "OSINT Collection Plan v2",
  "description": "Schema for hierarchical OSINT collection plans — supports master plans with defaults/children and child plans with sources/scoring.",
  "type": "object",
  "required": ["version", "plan_id", "plan_type"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 2,
      "description": "Schema version, must be 2."
    },
    "plan_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$",
      "description": "Unique lowercase-hyphenated identifier for the plan."
    },
    "plan_type": {
      "type": "string",
      "enum": ["master", "child"],
      "description": "Whether this is a master plan (defines defaults and children) or a child plan (defines sources and scoring)."
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Human-readable description of the plan."
    },
    "parent_plan_id": {
      "type": "string",
      "description": "Plan ID of the parent master plan (child plans only)."
    },
    "retention_class": {
      "type": "string",
      "enum": ["ephemeral", "standard", "evidentiary"],
      "default": "standard",
      "description": "Data retention class governing how long collected items are stored."
    },
    "defaults": {
      "type": "object",
      "description": "Default scoring and notification settings inherited by child plans (master plans only).",
      "properties": {
        "scoring": {
          "$ref": "#/$defs/scoring"
        },
        "notifications": {
          "$ref": "#/$defs/notifications"
        }
      },
      "additionalProperties": false
    },
    "children": {
      "type": "array",
      "description": "List of child plan references (master plans only).",
      "items": {
        "type": "object",
        "required": ["plan_id"],
        "properties": {
          "plan_id": {
            "type": "string",
            "description": "Plan ID of the child plan."
          }
        },
        "additionalProperties": false
      }
    },
    "watches": {
      "type": "array",
      "description": "Geographic or thematic watch definitions (master plans only).",
      "items": {
        "$ref": "#/$defs/watch"
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "description": "List of OSINT sources to collect from (child plans only).",
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "scoring": {
      "$ref": "#/$defs/scoring"
    },
    "notifications": {
      "$ref": "#/$defs/notifications"
    },
    "keywords": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Topic keywords for relevance scoring. Events matching more keywords score higher."
    },
    "source_profiles": {
      "type": "object",
      "description": "Map of source IDs to reliability/credibility profiles (child plans only).",
      "additionalProperties": {
        "$ref": "#/$defs/source_profile"
      }
    },
    "enrichment": {
      "$ref": "#/$defs/enrichment"
    },
    "target_geo": {
      "$ref": "#/$defs/target_geo"
    },
    "custom": {
      "type": "object",
      "description": "Plan-specific custom configuration (lead thresholds, report schedule, notification settings, etc.).",
      "additionalProperties": true
    }
  },
  "if": {
    "properties": {
      "plan_type": { "const": "master" }
    }
  },
  "then": {
    "required": ["defaults"]
  },
  "else": {
    "required": ["sources", "scoring", "notifications"]
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Unique identifier for this source within the plan."
        },
        "type": {
          "type": "string",
          "enum": [
            "rss",
            "sitemap",
            "http_html",
            "http_pdf",
            "http_json",
            "nvd_json_feed",
            "osv_api",
            "cisa_kev",
            "urlhaus_api",
            "threatfox_api",
            "github_releases",
            "gdelt_api",
            "reliefweb_api",
            "shodan_api",
            "otx_api",
            "abusech_malwarebazaar",
            "abusech_feodotracker",
            "acled_api",
            "nws_alerts",
            "reddit",
            "xai_x_search",
            "university_policy"
          ],
          "description": "Source collector type."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL endpoint for the source."
        },
        "weight": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0,
          "default": 1.0,
          "description": "Scoring weight multiplier for items from this source."
        },
        "schedule_cron": {
          "type": "string",
          "description": "Cron expression for collection schedule."
        },
        "params": {
          "type": "object",
          "description": "Arbitrary source-specific parameters.",
          "additionalProperties": true
        }
      }
    },
    "scoring": {
      "type": "object",
      "properties": {
        "recency_half_life_hours": {
          "type": "number",
          "minimum": 1,
          "maximum": 8760,
          "description": "Half-life in hours for the recency decay function."
        },
        "source_reputation": {
          "type": "object",
          "description": "Map of source id to reputation multiplier.",
          "additionalProperties": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 10.0
          }
        },
        "ioc_match_boost": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 100.0,
          "description": "Score multiplier when an IOC match is found."
        },
        "force_alert": {
          "type": "object",
          "description": "Conditions that force an immediate alert regardless of score.",
          "additionalProperties": false,
          "properties": {
            "min_severity": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"],
              "description": "Minimum severity level to trigger a forced alert."
            },
            "tags_any": {
              "type": "array",
              "items": { "type": "string" },
              "description": "If any of these tags are present, force an alert."
            }
          }
        },
        "severity_promotions": {
          "type": "array",
          "description": "Rules that can promote severity based on event conditions.",
          "items": {
            "type": "object",
            "properties": {
              "condition": { "type": "object" },
              "promote_to": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              }
            }
          }
        },
        "keyword_miss_penalty": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.05,
          "description": "Relevance score when no keywords match."
        }
      },
      "additionalProperties": false
    },
    "target_geo": {
      "type": "object",
      "description": "Target geographic area for relevance scoring.",
      "properties": {
        "country_codes": { "type": "array", "items": { "type": "string" } },
        "lat": { "type": "number" },
        "lon": { "type": "number" },
        "radius_km": { "type": "number", "minimum": 0 }
      }
    },
    "enrichment": {
      "type": "object",
      "description": "NLP enrichment configuration.",
      "properties": {
        "nlp_enabled": { "type": "boolean", "default": false },
        "mission": { "type": "string" },
        "classify_relevance": { "type": "boolean", "default": true },
        "extract_entities": { "type": "boolean", "default": true },
        "generate_summaries": { "type": "boolean", "default": true },
        "constitutional_classification": {
          "type": "boolean",
          "default": false,
          "description": "Enable constitutional rights classification for prospecting plans."
        }
      }
    },
    "notifications": {
      "type": "object",
      "required": ["routes"],
      "additionalProperties": false,
      "description": "Notification routing and deduplication settings.",
      "properties": {
        "default_dedupe_window_minutes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10080,
          "default": 60,
          "description": "Default deduplication window in minutes."
        },
        "quiet_hours": {
          "type": "object",
          "description": "Suppress non-critical notifications during these hours.",
          "additionalProperties": false,
          "properties": {
            "timezone": {
              "type": "string",
              "description": "IANA timezone identifier."
            },
            "start": {
              "type": "string",
              "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
              "description": "Start time in HH:MM format."
            },
            "end": {
              "type": "string",
              "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
              "description": "End time in HH:MM format."
            }
          }
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "description": "Notification routing rules evaluated in order.",
          "items": {
            "type": "object",
            "required": ["name", "channels"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Human-readable name for this route."
              },
              "when": {
                "type": "object",
                "description": "Conditions that must be met to trigger this route.",
                "additionalProperties": false,
                "properties": {
                  "severity_gte": {
                    "type": "string",
                    "enum": ["low", "medium", "high", "critical"],
                    "description": "Minimum severity level."
                  },
                  "tags_any": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Match if any of these tags are present."
                  },
                  "source_ids": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Match only items from these source ids."
                  }
                }
              },
              "channels": {
                "type": "array",
                "minItems": 1,
                "description": "Notification channels to dispatch to.",
                "items": {
                  "type": "object",
                  "required": ["type"],
                  "additionalProperties": false,
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["gotify", "slack", "email", "webhook"],
                      "description": "Channel type."
                    },
                    "application": {
                      "type": "string",
                      "description": "Application name (gotify)."
                    },
                    "priority": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 10,
                      "description": "Notification priority (gotify)."
                    },
                    "url": {
                      "type": "string",
                      "format": "uri",
                      "description": "Webhook URL or endpoint."
                    },
                    "to": {
                      "type": "string",
                      "description": "Email recipient address."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "watch": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "description": "A geographic or thematic watch definition.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name for this watch."
        },
        "country_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]{2,3}$"
          },
          "description": "ISO 3166-1 alpha-2 or alpha-3 country codes to monitor."
        },
        "region": {
          "type": "string",
          "description": "Human-readable region name."
        },
        "severity_threshold": {
          "type": "string",
          "enum": ["info", "low", "medium", "high", "critical"],
          "description": "Minimum severity to trigger alerts for this watch."
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords to match in event titles and summaries."
        }
      }
    },
    "source_profile": {
      "type": "object",
      "description": "NATO-style source reliability and information credibility profile.",
      "additionalProperties": false,
      "properties": {
        "reliability": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "E", "F"],
          "description": "Source reliability rating (A=completely reliable, F=reliability cannot be judged)."
        },
        "credibility": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "description": "Information credibility rating (1=confirmed, 6=truth cannot be judged)."
        },
        "corroboration_required": {
          "type": "boolean",
          "default": false,
          "description": "Whether items from this source require corroboration before alerting."
        },
        "license": {
          "type": "string",
          "description": "Data license or usage restrictions for this source."
        }
      }
    }
  }
}
