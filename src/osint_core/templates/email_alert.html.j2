<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<style>
  body { margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background: #f4f4f7; }
  .container { max-width: 600px; margin: 0 auto; padding: 20px; }
  .header { padding: 16px 24px; border-radius: 8px 8px 0 0; color: #fff; }
  .header h1 { margin: 0; font-size: 20px; }
  .severity-critical { background: #dc2626; }
  .severity-high { background: #ea580c; }
  .severity-medium { background: #d97706; }
  .severity-low { background: #2563eb; }
  .severity-info { background: #6b7280; }
  .body { background: #fff; padding: 24px; border-radius: 0 0 8px 8px; border: 1px solid #e5e7eb; border-top: none; }
  .label { font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
  .value { font-size: 14px; color: #1f2937; margin-bottom: 16px; }
  .indicators { margin-top: 16px; }
  .indicator { display: inline-block; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 4px; padding: 2px 8px; margin: 2px 4px 2px 0; font-size: 13px; font-family: monospace; color: #374151; }
  .footer { text-align: center; padding: 16px; font-size: 12px; color: #9ca3af; }
  .link { display: inline-block; margin-top: 16px; padding: 8px 16px; background: #2563eb; color: #fff; text-decoration: none; border-radius: 4px; font-size: 14px; }
</style>
</head>
<body>
<div class="container">
  <div class="header severity-{{ severity }}">
    <h1>{{ title }}</h1>
  </div>
  <div class="body">
    <div class="label">Severity</div>
    <div class="value">{{ severity | upper }}</div>

    <div class="label">Summary</div>
    <div class="value">{{ summary }}</div>

    {% if source_id %}
    <div class="label">Source</div>
    <div class="value">{{ source_id }}{% if event_type %} / {{ event_type }}{% endif %}</div>
    {% endif %}

    {% if indicators %}
    <div class="indicators">
      <div class="label">Indicators</div>
      <div class="value">
        {% for ind in indicators %}
        <span class="indicator">{{ ind }}</span>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if link %}
    <a class="link" href="{{ link }}">View Event</a>
    {% endif %}
  </div>
  <div class="footer">
    OSINT-Core Alert Notification
  </div>
</div>
</body>
</html>
